{
  "name": "blaise-login-react",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "blaise-login-react-client",
    "blaise-login-react-server"
  ],
  "dependenciesMeta": {
    "blaise-api-node-client": {
      "built": true
    },
    "blaise-design-system-react-components": {
      "built": true
    },
    "blaise-iap-node-provider": {
      "built": true
    }
  },
  "scripts": {
    "build:all": "yarn build:client && yarn build:server",
    "build:client": "yarn workspace blaise-login-react-client build",
    "build:server": "yarn workspace blaise-login-react-server build",
    "lint:all": "yarn lint:client && yarn lint:server",
    "lint:client": "yarn workspace blaise-login-react-client lint",
    "lint:server": "yarn workspace blaise-login-react-server lint",
    "lint-fix:all": "yarn lint-fix:client && yarn lint-fix:server",
    "lint-fix:client": "yarn workspace blaise-login-react-client lint-fix",
    "lint-fix:server": "yarn workspace blaise-login-react-server lint-fix",
    "spellcheck:all": "yarn spellcheck:client && yarn spellcheck:server",
    "spellcheck:client": "yarn workspace blaise-login-react-client spellcheck",
    "spellcheck:server": "yarn workspace blaise-login-react-server spellcheck",
    "test:all": "yarn test:client && yarn test:server",
    "test:client": "yarn workspace blaise-login-react-client test",
    "test:server": "yarn workspace blaise-login-react-server test"
  },
  "packageManager": "yarn@4.14.1"
}
